<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Midnight_Launcher.ExperimentalMainWindow"
        Title="Midnight Launcher (EXPERIMENTAL)"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">
    <Grid>
        <StackPanel VerticalAlignment="Top" Background="#FF3300" Height="30">
            <TextBlock Text="EXPERIMENTAL UI - NOT SUPPORTED" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="White"/>
        </StackPanel>
        
        <Grid ColumnDefinitions="300, *">
            <Border Grid.Column="0" Background="#11FFFFFF" Margin="0,30,0,0">
                <StackPanel Margin="20" Spacing="10">
                    <TextBlock Text="EXPERIMENTAL" FontSize="24" FontWeight="Black"/>
                    <Button Content="Return to Main UI" x:Name="ReturnButton" HorizontalAlignment="Stretch" Margin="0,20,0,0"/>
                </StackPanel>
            </Border>
            
            <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="This UI is a scrapped concept. Use at your own risk." FontSize="20" Foreground="#666666"/>
            </Grid>
        </Grid>
    </Grid>
</Window>
