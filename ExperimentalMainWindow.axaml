<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Midnight_Launcher.ExperimentalMainWindow"
        Title="Midnight Launcher (EXPERIMENTAL)"
        Width="1000" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="#0A0A0A"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                <GradientStop Color="#0F0F0F" Offset="0"/>
                <GradientStop Color="#1A0A1A" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel VerticalAlignment="Top" Background="#CCFF3300" Height="35">
            <TextBlock Text="⚠️ EXPERIMENTAL UI - SCRAPPED CONCEPT - NOT SUPPORTED" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" 
                       FontSize="12" FontWeight="Bold" Foreground="White"/>
        </StackPanel>
        
        <Grid ColumnDefinitions="280, *">
            <Border Grid.Column="0" Background="#1AFFFFFF" Margin="0,35,0,0" CornerRadius="0,20,0,0">
                <StackPanel Margin="30" Spacing="20">
                    <Image Source="avares://Midnight_Launcher/Assets/app_icon.png" Width="80" Height="80" HorizontalAlignment="Left"/>
                    <TextBlock Text="MIDNIGHT" FontSize="32" FontWeight="Black" LetterSpacing="2"/>
                    <TextBlock Text="Experimental Build" FontSize="12" Opacity="0.5" Margin="0,-15,0,0"/>
                    
                    <Separator Background="#33FFFFFF" Margin="0,10"/>
                    
                    <Button Content="Return to Safety" x:Name="ReturnButton" 
                            HorizontalAlignment="Stretch" Padding="15"
                            Background="#33FFFFFF" CornerRadius="10"/>
                </StackPanel>
            </Border>
            
            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <TextBlock Text="Welcome to the Void." FontSize="42" FontWeight="Thin" HorizontalAlignment="Center"/>
                <TextBlock Text="This UI was a concept that never made it to production." 
                           FontSize="16" Foreground="#888888" TextAlignment="Center" MaxWidth="400" TextWrapping="Wrap"/>
                <Border Background="#11FFFFFF" Padding="20" CornerRadius="15" Margin="0,20,0,0">
                    <TextBlock Text="Expect bugs. No support will be provided for this mode." 
                               Foreground="#FF5555" FontWeight="SemiBold"/>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
