<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="Midnight_Launcher.MainWindow"
        Title="Midnight Launcher"
        Width="980" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        Foreground="White">
    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.86" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="260,*">
            <Border Grid.Column="0" Background="#0A0A0A" Opacity="0.84" BorderThickness="0,0,1,0" BorderBrush="#252525">
                <Grid RowDefinitions="Auto,*,Auto">
                    <StackPanel Grid.Row="0" Margin="35,58,35,40" Spacing="20">
                        <Border Width="50" Height="50" CornerRadius="12" Background="#0078D4" BoxShadow="0 8 20 0 #40000000">
                            <PathIcon Data="{StaticResource IconMods}" Width="28" Height="28" Foreground="White"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="MIDNIGHT" FontSize="20" FontWeight="Black" LetterSpacing="3" Foreground="White"/>
                            <TextBlock Text="LAUNCHER" FontSize="11" FontWeight="Light" LetterSpacing="5" Foreground="#0078D4" Margin="2,0,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <ListBox x:Name="NavListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="15,0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="20,14"/>
                                <Setter Property="CornerRadius" Value="12"/>
                                <Setter Property="Margin" Value="0,4"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Transitions">
                                    <Transitions>
                                        <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                    </Transitions>
                                </Setter>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#1A1A1A"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected PathIcon">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="Opacity" Value="1.0"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBoxItem x:Name="HomeNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconHome}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Home" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="AccountsNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconAccounts}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Accounts" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="NewsNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconNews}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="News" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ModsNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconMods}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Mods" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ModloadersNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconModloaders}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Modloaders" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ChangelogsNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconChangelogs}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Changelogs" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="SettingsNav">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <PathIcon Data="{StaticResource IconSettings}" Width="20" Height="20" Opacity="0.5"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="15" FontWeight="Medium"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="30" Spacing="5">
                        <TextBlock x:Name="LauncherVersionText" Text="v1.1.9 Stable" FontSize="11" Opacity="0.4" HorizontalAlignment="Center" FontWeight="Light"/>
                        <TextBlock Text="© 2026 CStudioss" FontSize="10" Opacity="0.2" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*" Margin="50,60,50,50">
                <StackPanel Grid.Row="0" Margin="0,0,0,50" Spacing="5">
                    <TextBlock x:Name="ViewTitle" Text="Home" FontSize="36" FontWeight="Black" LetterSpacing="-1"/>
                    <Rectangle Height="4" Width="40" Fill="#0078D4" HorizontalAlignment="Left" RadiusX="2" RadiusY="2"/>
                </StackPanel>

                <Panel Grid.Row="1">
                    <Grid x:Name="HomeView">
                        <Grid RowDefinitions="*,Auto">
                            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="50">
                                <Border Width="200" Height="200" CornerRadius="100" Background="#0F0F0F" BoxShadow="0 15 40 0 #60000000">
                                    <PathIcon Data="{StaticResource IconMods}" Width="90" Height="90" Foreground="#0078D4"/>
                                </Border>

                                <Grid ColumnDefinitions="*,20,*" Width="500">
                                    <Border Grid.Column="0" Background="#161616" CornerRadius="16" Padding="20,12" BorderThickness="1" BorderBrush="#252525">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="ACTIVE ACCOUNT" FontSize="10" FontWeight="Black" Opacity="0.4" LetterSpacing="1"/>
                                            <ComboBox x:Name="AccountComboBox" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" FontSize="15"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="#161616" CornerRadius="16" Padding="20,12" BorderThickness="1" BorderBrush="#252525">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="GAME VERSION" FontSize="10" FontWeight="Black" Opacity="0.4" LetterSpacing="1"/>
                                            <Grid ColumnDefinitions="*,Auto">
                                                <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" Grid.Column="0" FontSize="15"/>
                                                <Button x:Name="RefreshVersionsButton" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="8" VerticalAlignment="Center">
                                                    <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16" Opacity="0.5"/>
                                                </Button>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>

                            <Grid Grid.Row="1" ColumnDefinitions="*,300" VerticalAlignment="Bottom" Margin="0,0,0,10">
                                <StackPanel Grid.Column="0" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock x:Name="StatusTextBlock" Text="System Status: Ready" FontSize="12" FontWeight="SemiBold" Opacity="0.5"/>
                                    <ProgressBar x:Name="DownloadProgressBar" Height="10" CornerRadius="5" Background="#161616" Foreground="#0078D4" BorderThickness="0"/>
                                </StackPanel>

                                <Border Grid.Column="1" Height="80" CornerRadius="20" Background="#0078D4" BoxShadow="0 10 25 0 #300078D4">
                                    <Button x:Name="PlayButton" Background="Transparent" BorderThickness="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" CornerRadius="20">
                                        <Grid ColumnDefinitions="Auto,*">
                                            <Border Grid.Column="0" Width="50" Height="50" CornerRadius="15" Background="#FFFFFF" Opacity="0.1" Margin="15,0">
                                                <PathIcon Data="{StaticResource IconPlay}" Width="20" Height="20" Foreground="White"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,30,0">
                                                <TextBlock Text="LAUNCH GAME" FontSize="18" FontWeight="Black" LetterSpacing="1"/>
                                                <TextBlock Text="Ready to play" FontSize="11" Opacity="0.6"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <Grid x:Name="AccountsView" IsVisible="False" RowDefinitions="*,Auto">
                        <ListBox x:Name="AccountsListBox" Grid.Row="0" Background="#0F0F0F" CornerRadius="20" BorderThickness="1" BorderBrush="#252525" Padding="10">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="20,15"/>
                                    <Setter Property="CornerRadius" Value="12"/>
                                    <Setter Property="Margin" Value="5"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161616" CornerRadius="12" Padding="14,10" BorderBrush="#252525" BorderThickness="1">
                                        <TextBlock Text="{Binding}" FontWeight="SemiBold" FontSize="14"/>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                        <Border Grid.Row="1" Margin="0,30,0,0" Background="#161616" CornerRadius="20" Padding="10" BorderThickness="1" BorderBrush="#252525">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="NewUsernameTextBox" Watermark="Enter username..." Height="55" Background="Transparent" BorderThickness="0" FontSize="16" Padding="20,0"/>
                                <Button x:Name="AddAccountButton" Grid.Column="1" Height="55" Padding="30,0" CornerRadius="15" Background="#0078D4">
                                    <TextBlock Text="REGISTER ACCOUNT" Foreground="White" FontWeight="Black" FontSize="13" LetterSpacing="1"/>
                                </Button>
                            </Grid>
                        </Border>
                    </Grid>

                    <ScrollViewer x:Name="SettingsView" IsVisible="False">
                        <StackPanel Spacing="35">
                            <Border Background="#161616" Padding="30" CornerRadius="24" BorderThickness="1" BorderBrush="#252525">
                                <StackPanel Spacing="30">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="SYSTEM" FontSize="11" FontWeight="Black" Foreground="#0078D4" LetterSpacing="2"/>
                                        <TextBlock Text="Launcher Configuration" FontSize="20" FontWeight="Bold"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="RAM Allocation" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="Adjust memory for game stability" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                                            <TextBlock x:Name="RamValueText" Text="4096 MB" Foreground="#0078D4" FontWeight="Black" VerticalAlignment="Center" Width="80" TextAlignment="Right"/>
                                            <Slider x:Name="RamSlider" Minimum="1024" Maximum="16384" Value="4096" Width="200" Foreground="#0078D4"/>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Background="#252525"/>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="Visual Theme" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="Customize the interface aesthetic" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox" Grid.Column="1" Width="200" CornerRadius="10" Height="45">
                                            <ComboBoxItem Content="Midnight"/>
                                            <ComboBoxItem Content="Dark"/>
                                            <ComboBoxItem Content="Light"/>
                                        </ComboBox>
                                    </Grid>

                                    <Separator Background="#252525"/>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="Installation Directory" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="Path: managed per-user game folder" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="12">
                                            <Button x:Name="ChangeFolderButton" Content="BROWSE" Background="#2A2A2A" CornerRadius="10" Padding="25,12" FontSize="12" FontWeight="Bold"/>
                                            <Button x:Name="OpenFolderButton" Background="#2A2A2A" CornerRadius="10" Padding="15">
                                                <PathIcon Data="{StaticResource IconFolder}" Width="18" Height="18" Opacity="0.7"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#161616" Padding="30" CornerRadius="24" BorderThickness="1" BorderBrush="#252525">
                                <StackPanel Spacing="25">
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="MAINTENANCE" FontSize="11" FontWeight="Black" Foreground="#0078D4" LetterSpacing="2"/>
                                        <TextBlock Text="Updates &amp; Support" FontSize="20" FontWeight="Bold"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="Automatic Updates" FontWeight="Bold" FontSize="15"/>
                                            <TextBlock Text="Check for the latest launcher release" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                                            <Button x:Name="CheckUpdatesButton" Background="#0078D4" CornerRadius="10" Padding="25,12">
                                                <TextBlock Text="CHECK NOW" Foreground="White" FontSize="12" FontWeight="Black" LetterSpacing="1"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <Separator Background="#252525"/>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Spacing="5">
                                            <TextBlock Text="Experimental UI" FontWeight="Bold" FontSize="15" Foreground="#FFCC00"/>
                                            <TextBlock Text="Enable the alternate concept window" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ExperimentalUiToggle" Grid.Column="1" OnContent="Active" OffContent="Stable"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid x:Name="NewsView" IsVisible="False">
                        <ListBox x:Name="NewsListBox" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161616" Margin="0,0,0,20" Padding="25" CornerRadius="24" BorderThickness="1" BorderBrush="#252525">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding Title}" FontWeight="Black" FontSize="20" LetterSpacing="-0.5"/>
                                            <TextBlock Text="{Binding Date}" FontSize="12" Opacity="0.4" FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Summary}" FontSize="14" Opacity="0.7" TextWrapping="Wrap" LineHeight="20"/>
                                            <TextBlock Text="Click the item to open the article." FontSize="11" Opacity="0.35"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid x:Name="ModloadersView" IsVisible="False">
                        <StackPanel Spacing="40" VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                            <StackPanel Spacing="10" HorizontalAlignment="Center">
                                <TextBlock Text="MODLOADER RESOURCES" FontSize="11" FontWeight="Black" Foreground="#0078D4" LetterSpacing="3" HorizontalAlignment="Center"/>
                                <TextBlock Text="Installer shortcuts" FontSize="28" FontWeight="Black" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <Border Background="#161616" Padding="30" CornerRadius="24" BorderThickness="1" BorderBrush="#252525">
                                <StackPanel Spacing="25">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="SELECT TARGET VERSION" FontSize="10" FontWeight="Black" Opacity="0.4" LetterSpacing="1"/>
                                        <ComboBox x:Name="ModloaderVersionComboBox" HorizontalAlignment="Stretch" CornerRadius="12" Height="50" FontSize="16"/>
                                    </StackPanel>

                                    <Grid ColumnDefinitions="*,*">
                                        <Button x:Name="InstallForgeButton" Grid.Column="0" Margin="0,0,10,0" Height="70" CornerRadius="18" Background="#DF9444" HorizontalAlignment="Stretch">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="OPEN FORGE" FontWeight="Black" FontSize="18" HorizontalAlignment="Center" LetterSpacing="1"/>
                                                <TextBlock Text="Installer resources" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button x:Name="InstallFabricButton" Grid.Column="1" Margin="10,0,0,0" Height="70" CornerRadius="18" Background="#F0D697" HorizontalAlignment="Stretch">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="OPEN FABRIC" Foreground="Black" FontWeight="Black" FontSize="18" HorizontalAlignment="Center" LetterSpacing="1"/>
                                                <TextBlock Text="Installer resources" Foreground="Black" FontSize="10" Opacity="0.6" HorizontalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ChangelogsView" IsVisible="False" ColumnDefinitions="300,*">
                        <ListBox x:Name="ChangelogVersionListBox" Grid.Column="0" Background="#0F0F0F" CornerRadius="24,0,0,24" BorderThickness="1,1,0,1" BorderBrush="#252525"/>
                        <Border Grid.Column="1" Background="#141414" CornerRadius="0,24,24,0" Padding="40" BorderThickness="0,1,1,1" BorderBrush="#252525">
                            <ScrollViewer>
                                <TextBlock x:Name="ChangelogContentText" FontSize="15" LineHeight="28" TextWrapping="Wrap" Opacity="0.9" FontWeight="Medium"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid x:Name="ModsView" IsVisible="False" RowDefinitions="Auto,*">
                        <Border Grid.Row="0" Background="#161616" CornerRadius="18" Padding="10" Margin="0,0,0,30" BorderThickness="1" BorderBrush="#252525">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="ModSearchTextBox" Watermark="Search for mods on Modrinth..." Height="50" Background="Transparent" BorderThickness="0" FontSize="16" Padding="20,0"/>
                                <Button x:Name="SearchModsButton" Grid.Column="1" Margin="10,0,0,0" Height="50" Padding="30,0" CornerRadius="12" Background="#0078D4">
                                    <TextBlock Text="SEARCH" Foreground="White" FontWeight="Black" FontSize="12" LetterSpacing="1"/>
                                </Button>
                            </Grid>
                        </Border>
                        <ListBox x:Name="ModsListBox" Grid.Row="1" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#161616" Margin="0,0,0,16" Padding="22" CornerRadius="20" BorderThickness="1" BorderBrush="#252525">
                                        <StackPanel Spacing="8">
                                            <TextBlock Text="{Binding Title}" FontWeight="Black" FontSize="18"/>
                                            <TextBlock Text="{Binding Description}" FontSize="13" Opacity="0.75" TextWrapping="Wrap" MaxLines="3" LineHeight="18"/>
                                            <TextBlock Text="{Binding ProjectUrl}" FontSize="11" Opacity="0.35"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Panel>
            </Grid>
        </Grid>

        <Grid x:Name="LoadingOverlay" Background="#F8000000" IsVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="35">
                <Border Width="120" Height="120" CornerRadius="30" Background="#0078D4" BoxShadow="0 15 35 0 #800078D4">
                    <PathIcon Data="{StaticResource IconMods}" Width="60" Height="60" Foreground="White">
                        <PathIcon.Styles>
                            <Style Selector="PathIcon">
                                <Style.Animations>
                                    <Animation Duration="0:0:1" IterationCount="Infinite">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="ScaleTransform.ScaleX" Value="0.8"/>
                                            <Setter Property="ScaleTransform.ScaleY" Value="0.8"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="50%">
                                            <Setter Property="ScaleTransform.ScaleX" Value="1.1"/>
                                            <Setter Property="ScaleTransform.ScaleY" Value="1.1"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="ScaleTransform.ScaleX" Value="0.8"/>
                                            <Setter Property="ScaleTransform.ScaleY" Value="0.8"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </PathIcon.Styles>
                        <PathIcon.RenderTransform>
                            <ScaleTransform />
                        </PathIcon.RenderTransform>
                    </PathIcon>
                </Border>
                <StackPanel Spacing="15">
                    <ProgressBar IsIndeterminate="True" Width="240" Height="4" Foreground="#0078D4" Background="#161616" BorderThickness="0" CornerRadius="2"/>
                    <TextBlock x:Name="LoadingStatus" Text="Initializing System..." FontSize="14" FontWeight="Black" Opacity="0.4" HorizontalAlignment="Center" LetterSpacing="2"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid x:Name="BrandingOverlay" Background="#000000" IsVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="30">
                <PathIcon Data="{StaticResource IconHeart}" Width="120" Height="120" Foreground="#E91E63"/>
                <TextBlock Text="CSTUDIOSS" FontSize="16" FontWeight="Black" LetterSpacing="8" Opacity="0.4" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="NotificationArea" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="40" Width="350" Spacing="15"/>
    </Panel>
</Window>
