<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="Midnight_Launcher.MainWindow"
        Title="Midnight Launcher"
        Width="900" Height="600"
        WindowStartupLocation="CenterScreen"
        Background="#121212"
        Foreground="White">
    <Grid>
        <!-- Main Layout -->
        <Grid ColumnDefinitions="220, *">
            <!-- Sidebar -->
            <StackPanel Grid.Column="0" Background="#1E1E1E" Spacing="0">
                <StackPanel Orientation="Horizontal" Margin="20" Spacing="15">
                    <Image Source="avares://Midnight_Launcher/Assets/app_icon.png" Width="40" Height="40"/>
                    <TextBlock Text="Midnight" VerticalAlignment="Center" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                
                <ListBox x:Name="NavListBox" Background="Transparent" BorderThickness="0" Margin="10,0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="15,10"/>
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBoxItem x:Name="HomeNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/home.png" Width="20" Height="20"/>
                            <TextBlock Text="Home" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="AccountsNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/accounts.png" Width="20" Height="20"/>
                            <TextBlock Text="Accounts" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NewsNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/news.png" Width="20" Height="20"/>
                            <TextBlock Text="News" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="ModsNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/modrinth.png" Width="20" Height="20"/>
                            <TextBlock Text="Mods" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="ModloadersNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/modloaders.png" Width="20" Height="20"/>
                            <TextBlock Text="Modloaders" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="ChangelogsNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/changelogs.png" Width="20" Height="20"/>
                            <TextBlock Text="Changelogs" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                    <ListBoxItem x:Name="SettingsNav">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/settings.png" Width="20" Height="20"/>
                            <TextBlock Text="Settings" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>

            <!-- Content Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Margin="30">
                <!-- Header -->
                <TextBlock x:Name="ViewTitle" Text="Home" FontSize="28" FontWeight="SemiBold" Grid.Row="0"/>

                <!-- Main Content (Home View) -->
                <StackPanel x:Name="HomeView" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="30">
                    <Image Source="avares://Midnight_Launcher/Assets/app_icon.png" Width="150" Height="150"/>
                    
                    <StackPanel Spacing="10" Width="300">
                        <TextBlock Text="Account" FontSize="14" Foreground="#AAAAAA"/>
                        <ComboBox x:Name="AccountComboBox" HorizontalAlignment="Stretch" Background="#2A2A2A"/>
                    </StackPanel>

                    <StackPanel Spacing="10" Width="300">
                        <TextBlock Text="Version" FontSize="14" Foreground="#AAAAAA"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch" Background="#2A2A2A" Grid.Column="0"/>
                            <Button x:Name="RefreshVersionsButton" Grid.Column="1" Margin="5,0,0,0" Background="#2A2A2A" Padding="8">
                                <Image Source="avares://Midnight_Launcher/Assets/refresh.png" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Accounts Content -->
                <StackPanel x:Name="AccountsView" Grid.Row="1" Spacing="20" IsVisible="False">
                    <TextBlock Text="Manage Accounts" FontSize="20" Margin="0,0,0,10"/>
                    <ListBox x:Name="AccountsListBox" Height="200" Background="#1E1E1E" CornerRadius="8"/>
                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                        <TextBox x:Name="NewUsernameTextBox" Watermark="New Username" Grid.Column="0" Background="#2A2A2A"/>
                        <Button x:Name="AddAccountButton" Content="Add Account" Margin="10,0,0,0" Grid.Column="1" Padding="15,8"/>
                    </Grid>
                </StackPanel>

                <!-- Settings Content -->
                <StackPanel x:Name="SettingsView" Grid.Row="1" Spacing="25" IsVisible="False">
                    <TextBlock Text="Settings" FontSize="20" Margin="0,0,0,10"/>
                    
                    <Border Background="#1E1E1E" Padding="20" CornerRadius="8">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Game Configuration" FontWeight="Bold" FontSize="16"/>
                            <Separator Background="#2A2A2A"/>
                            
                            <!-- RAM Allocation -->
                            <StackPanel Spacing="5">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="RAM Allocation" FontWeight="SemiBold"/>
                                        <TextBlock Text="Set the maximum memory for Minecraft." FontSize="12" Foreground="#AAAAAA"/>
                                    </StackPanel>
                                    <TextBlock x:Name="RamValueText" Text="4096 MB" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold"/>
                                </Grid>
                                <Slider x:Name="RamSlider" Minimum="1024" Maximum="16384" Value="4096" SmallChange="512" LargeChange="1024" Foreground="#FF2196F3"/>
                            </StackPanel>

                            <Separator Background="#2A2A2A"/>

                            <!-- Theme Selection -->
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="UI Theme" FontWeight="SemiBold"/>
                                    <TextBlock Text="Switch between different UI styles." FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <ComboBox x:Name="ThemeComboBox" Grid.Column="1" Width="150" Background="#2A2A2A">
                                    <ComboBoxItem Content="Midnight"/>
                                    <ComboBoxItem Content="Dark"/>
                                    <ComboBoxItem Content="Light"/>
                                </ComboBox>
                            </Grid>

                            <Separator Background="#2A2A2A"/>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Game Folder" FontWeight="SemiBold"/>
                                    <TextBlock Text="Select where Minecraft files are stored." FontSize="12" Foreground="#AAAAAA"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10">
                                    <Button x:Name="ChangeFolderButton" Content="Change" Background="#2A2A2A" Padding="15,8"/>
                                    <Button x:Name="OpenFolderButton" Background="#2A2A2A" Padding="15,8">
                                        <Image Source="avares://Midnight_Launcher/Assets/folder.png" Width="16" Height="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E1E1E" Padding="20" CornerRadius="8">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Experimental Settings" FontWeight="Bold" FontSize="16" Foreground="#FFCC00"/>
                            <Separator Background="#2A2A2A"/>
                            <TextBlock Text="Note: This is a scrapped, modern UI that is less stable. Full compatibility is not guaranteed, and errors on it will not be supported." 
                                       FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="Enable Experimental Modern UI" VerticalAlignment="Center"/>
                                <ToggleSwitch x:Name="ExperimentalUiToggle" Grid.Column="1"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Modloaders Content -->
                <Grid x:Name="ModloadersView" Grid.Row="1" IsVisible="False">
                    <StackPanel Spacing="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                        <TextBlock Text="Install Forge or Fabric" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>
                        
                        <StackPanel Spacing="10">
                            <TextBlock Text="Select Minecraft Version:" FontSize="14" Foreground="#AAAAAA"/>
                            <ComboBox x:Name="ModloaderVersionComboBox" HorizontalAlignment="Stretch" Background="#2A2A2A"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*, *">
                            <Button x:Name="InstallForgeButton" Content="Install Forge" Grid.Column="0" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="15" Background="#DF9444" Foreground="Black" FontWeight="Bold" Margin="0,0,10,0"/>
                            <Button x:Name="InstallFabricButton" Content="Install Fabric" Grid.Column="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="15" Background="#F0D697" Foreground="Black" FontWeight="Bold" Margin="10,0,0,0"/>
                        </Grid>
                        <TextBlock Text="Note: This will download the modloader and create a new profile." FontSize="12" Foreground="#AAAAAA" TextAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Changelogs Content -->
                <Grid x:Name="ChangelogsView" Grid.Row="1" ColumnDefinitions="250, *" IsVisible="False">
                    <ListBox x:Name="ChangelogVersionListBox" Grid.Column="0" Background="#1E1E1E" CornerRadius="8,0,0,8"/>
                    <Border Grid.Column="1" Background="#1A1A1A" CornerRadius="0,8,8,0" Padding="20">
                        <ScrollViewer>
                            <TextBlock x:Name="ChangelogContentText" Text="Select a version to see its changes." TextWrapping="Wrap" LineHeight="22"/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- News Content -->
                <Grid x:Name="NewsView" Grid.Row="1" RowDefinitions="*, Auto" IsVisible="False">
                    <ListBox x:Name="NewsListBox" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" Margin="0,5" Padding="15" CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto, *">
                                        <Image Source="{Binding ImageUrl}" Width="120" Height="70" Stretch="UniformToFill" Margin="0,0,15,0" Grid.Column="0"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Date}" FontSize="12" Foreground="#AAAAAA" Margin="0,5"/>
                                            <TextBlock Text="{Binding Summary}" FontSize="13" TextWrapping="Wrap" MaxLines="2"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Grid x:Name="NewsArticleOverlay" IsVisible="False" Background="#121212" Grid.RowSpan="2" Margin="-30">
                        <Grid RowDefinitions="Auto, *">
                            <Button x:Name="CloseNewsButton" Content="Back to News" Margin="20" HorizontalAlignment="Left" Grid.Row="0"/>
                            <TextBlock Text="Full article opening in browser..." HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="1"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- Mods Content -->
                <Grid x:Name="ModsView" Grid.Row="1" RowDefinitions="Auto, *" IsVisible="False">
                    <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox x:Name="ModSearchTextBox" Watermark="Search Modrinth..." Grid.Column="0"/>
                            <Button x:Name="SearchModsButton" Content="Search" Margin="10,0,0,0" Grid.Column="1"/>
                        </Grid>
                    </StackPanel>
                    <ListBox x:Name="ModsListBox" Grid.Row="1" Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1E1E1E" Margin="0,5" Padding="15" CornerRadius="8">
                                    <Grid ColumnDefinitions="Auto, *, Auto">
                                        <Image Source="{Binding IconUrl}" Width="60" Height="60" Margin="0,0,15,0" Grid.Column="0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#AAAAAA" TextWrapping="Wrap" MaxLines="1"/>
                                        </StackPanel>
                                        <Button x:Name="InstallModButton" Content="Install" Grid.Column="2" VerticalAlignment="Center" Padding="15,8" Background="#1BD96A" Foreground="Black" FontWeight="Bold"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Footer (Play Button & Progress) -->
                <StackPanel Grid.Row="2" Spacing="15" Margin="0,20,0,0">
                    <Button x:Name="PlayButton" 
                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                            Padding="20" Background="#FF2196F3" Foreground="White" CornerRadius="8">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="avares://Midnight_Launcher/Assets/play.png" Width="24" Height="24"/>
                            <TextBlock Text="PLAY" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <StackPanel Spacing="5">
                        <ProgressBar x:Name="DownloadProgressBar" Height="6" Minimum="0" Maximum="100" CornerRadius="3" Background="#2A2A2A"/>
                        <TextBlock x:Name="StatusTextBlock" Text="Ready to Play" HorizontalAlignment="Center" Foreground="#AAAAAA" FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Background="#E6121212" IsVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <Image Source="avares://Midnight_Launcher/Assets/app_icon.png" Width="100" Height="100" Opacity="0.8">
                    <Image.Styles>
                        <Style Selector="Image">
                            <Style.Animations>
                                <Animation Duration="0:0:2" IterationCount="Infinite">
                                    <KeyFrame Cue="0%">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="50%">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </KeyFrame>
                                    <KeyFrame Cue="100%">
                                        <Setter Property="Opacity" Value="0.4"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </Image.Styles>
                </Image>
                <ProgressBar IsIndeterminate="True" Width="200" Height="4" Foreground="#FF2196F3" Background="Transparent"/>
                <TextBlock x:Name="LoadingStatus" Text="Preparing Midnight..." HorizontalAlignment="Center" FontSize="16" FontWeight="Light"/>
            </StackPanel>
        </Grid>
        <!-- Branding Overlay -->
        <Grid x:Name="BrandingOverlay" Background="#121212" IsVisible="False">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="60">
                <!-- Made with C++ -->
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <Image Source="avares://Midnight_Launcher/Assets/cpp_logo.png" Width="80" Height="80"/>
                    <TextBlock Text="Made With C++" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Made with Love (CStudioss) -->
                <StackPanel Spacing="15" HorizontalAlignment="Center">
                    <Image Source="avares://Midnight_Launcher/Assets/cstudioss_logo.png" Width="80" Height="80"/>
                    <TextBlock Text="Made With Love." FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="CStudioss" FontSize="12" Foreground="#E91E63" HorizontalAlignment="Center" Margin="0,-10,0,0"/>
                </StackPanel>
            </StackPanel>
            
            <Grid.Styles>
                <Style Selector="Grid#BrandingOverlay">
                    <Style.Animations>
                        <Animation Duration="0:0:3" FillMode="Forward" Easing="CubicEaseOut">
                            <KeyFrame Cue="0%">
                                <Setter Property="Opacity" Value="0.0"/>
                                <Setter Property="TranslateTransform.Y" Value="50"/>
                            </KeyFrame>
                            <KeyFrame Cue="20%">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="TranslateTransform.Y" Value="0"/>
                            </KeyFrame>
                            <KeyFrame Cue="80%">
                                <Setter Property="Opacity" Value="1.0"/>
                                <Setter Property="TranslateTransform.Y" Value="0"/>
                            </KeyFrame>
                            <KeyFrame Cue="100%">
                                <Setter Property="Opacity" Value="0.0"/>
                                <Setter Property="TranslateTransform.Y" Value="-50"/>
                            </KeyFrame>
                        </Animation>
                    </Style.Animations>
                </Style>
            </Grid.Styles>
            <Grid.RenderTransform>
                <TranslateTransform />
            </Grid.RenderTransform>
        </Grid>

        <!-- Notification Overlay -->
        <StackPanel x:Name="NotificationArea" 
                    VerticalAlignment="Bottom" 
                    HorizontalAlignment="Right" 
                    Margin="0,0,20,20" 
                    Width="300" 
                    Spacing="10">
            <!-- Notifications will be added here dynamically -->
        </StackPanel>
    </Grid>
</Window>
