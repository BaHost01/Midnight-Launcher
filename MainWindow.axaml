<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        x:Class="Midnight_Launcher.MainWindow"
        Title="Midnight Launcher"
        Width="950" Height="650"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        Foreground="White">
    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.75" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid ColumnDefinitions="240, *">
            <!-- Sidebar -->
            <Border Grid.Column="0" Background="#1A1A1A" Opacity="0.5" BorderThickness="0,0,1,0" BorderBrush="#333333">
                <Grid RowDefinitions="Auto, *, Auto">
                    <StackPanel Grid.Row="0" Margin="30,50,30,30" Spacing="15">
                        <PathIcon Data="{StaticResource IconMods}" Width="40" Height="40" Foreground="#0078D4"/>
                        <TextBlock Text="Midnight" FontSize="22" FontWeight="Bold" LetterSpacing="1"/>
                    </StackPanel>
                    
                    <ListBox x:Name="NavListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="15,0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="15,12"/>
                                <Setter Property="CornerRadius" Value="10"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="#252525"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="TextBlock.Foreground" Value="White"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBoxItem x:Name="HomeNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconHome}" Width="20" Height="20"/>
                                <TextBlock Text="Home" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="AccountsNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconAccounts}" Width="20" Height="20"/>
                                <TextBlock Text="Accounts" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="NewsNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconNews}" Width="20" Height="20"/>
                                <TextBlock Text="News" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ModsNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconMods}" Width="20" Height="20"/>
                                <TextBlock Text="Mods" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ModloadersNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconModloaders}" Width="20" Height="20"/>
                                <TextBlock Text="Modloaders" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="ChangelogsNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconChangelogs}" Width="20" Height="20"/>
                                <TextBlock Text="Changelogs" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                        <ListBoxItem x:Name="SettingsNav">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <PathIcon Data="{StaticResource IconSettings}" Width="20" Height="20"/>
                                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="15"/>
                            </StackPanel>
                        </ListBoxItem>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="25" Spacing="10">
                        <TextBlock Text="v1.1.6 Stable" FontSize="12" Opacity="0.5" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto" Margin="40,50,40,40">
                <!-- Header -->
                <TextBlock x:Name="ViewTitle" Text="Home" FontSize="32" FontWeight="Bold" Grid.Row="0" Margin="0,0,0,40"/>

                <!-- Content Views -->
                <Panel Grid.Row="1">
                    <!-- Home View -->
                    <StackPanel x:Name="HomeView" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="40">
                        <Border Width="160" Height="160" CornerRadius="80" Background="#121212" BoxShadow="0 10 30 0 #40000000">
                            <PathIcon Data="{StaticResource IconMods}" Width="80" Height="80" Foreground="#0078D4"/>
                        </Border>
                        
                        <StackPanel Spacing="15" Width="350">
                            <Border Background="#1E1E1E" CornerRadius="12" Padding="15,5">
                                <StackPanel>
                                    <TextBlock Text="ACCOUNT" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,5,0,0"/>
                                    <ComboBox x:Name="AccountComboBox" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#1E1E1E" CornerRadius="12" Padding="15,5">
                                <StackPanel>
                                    <TextBlock Text="VERSION" FontSize="11" FontWeight="Bold" Opacity="0.6" Margin="0,5,0,0"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <ComboBox x:Name="VersionComboBox" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0" Grid.Column="0"/>
                                        <Button x:Name="RefreshVersionsButton" Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="10">
                                            <PathIcon Data="{StaticResource IconRefresh}" Width="16" Height="16" Opacity="0.6"/>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <!-- Accounts View -->
                    <StackPanel x:Name="AccountsView" IsVisible="False" Spacing="25">
                        <ListBox x:Name="AccountsListBox" Height="300" Background="#1E1E1E" CornerRadius="15" BorderThickness="1" BorderBrush="#333333"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBox x:Name="NewUsernameTextBox" Watermark="Add offline account..." Height="45" Background="#1E1E1E" CornerRadius="10" BorderBrush="#333333"/>
                            <Button x:Name="AddAccountButton" Content="Add Account" Grid.Column="1" Margin="15,0,0,0" Height="45" Padding="25,0" CornerRadius="10" Background="#0078D4" Foreground="White" FontWeight="SemiBold"/>
                        </Grid>
                    </StackPanel>

                    <!-- Settings View -->
                    <ScrollViewer x:Name="SettingsView" IsVisible="False">
                        <StackPanel Spacing="30">
                            <Border Background="#1E1E1E" Padding="25" CornerRadius="15" BorderThickness="1" BorderBrush="#333333">
                                <StackPanel Spacing="25">
                                    <TextBlock Text="Game Configuration" FontWeight="Bold" FontSize="18"/>
                                    
                                    <StackPanel Spacing="10">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="RAM Allocation" FontWeight="SemiBold"/>
                                            <TextBlock x:Name="RamValueText" Text="4096 MB" Grid.Column="1" Foreground="#0078D4" FontWeight="Bold"/>
                                        </Grid>
                                        <Slider x:Name="RamSlider" Minimum="1024" Maximum="16384" Value="4096" Foreground="#0078D4"/>
                                    </StackPanel>

                                    <Separator Background="#333333"/>

                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel>
                                            <TextBlock Text="UI Theme" FontWeight="SemiBold"/>
                                            <TextBlock Text="Set your preferred visual style" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ThemeComboBox" Grid.Column="1" Width="180" CornerRadius="8">
                                            <ComboBoxItem Content="Midnight"/>
                                            <ComboBoxItem Content="Dark"/>
                                            <ComboBoxItem Content="Light"/>
                                        </ComboBox>
                                    </Grid>

                                    <Separator Background="#333333"/>
                                    
                                    <Grid ColumnDefinitions="*, Auto">
                                        <StackPanel>
                                            <TextBlock Text="Game Directory" FontWeight="SemiBold"/>
                                            <TextBlock Text="Path: ./game" FontSize="12" Opacity="0.5"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Grid.Column="1" Spacing="10">
                                            <Button x:Name="ChangeFolderButton" Content="Browse" Background="#2A2A2A" CornerRadius="8" Padding="15,8"/>
                                            <Button x:Name="OpenFolderButton" Background="#2A2A2A" CornerRadius="8" Padding="15,8">
                                                <PathIcon Data="{StaticResource IconFolder}" Width="16" Height="16"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Background="#251A00" Padding="25" CornerRadius="15" BorderThickness="1" BorderBrush="#4D3D00">
                                <StackPanel Spacing="15">
                                    <TextBlock Text="Experimental Modern UI" FontWeight="Bold" FontSize="18" Foreground="#FFCC00"/>
                                    <TextBlock Text="The modern UI is a complete redesign. While more aesthetic, it may be less stable." 
                                               FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                                    <ToggleSwitch x:Name="ExperimentalUiToggle" OnContent="Enabled" OffContent="Disabled"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- News, Mods, Modloaders, Changelogs Views (Simplified for brevity but styled similarly) -->
                    <Grid x:Name="NewsView" IsVisible="False">
                        <ListBox x:Name="NewsListBox" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#1E1E1E" Margin="0,0,0,15" Padding="20" CornerRadius="15" BorderThickness="1" BorderBrush="#333333">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <Border CornerRadius="10" ClipToBounds="True" Width="140" Height="80" Margin="0,0,20,0">
                                                <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="18"/>
                                                <TextBlock Text="{Binding Date}" FontSize="12" Opacity="0.5" Margin="0,5"/>
                                                <TextBlock Text="{Binding Summary}" FontSize="14" Opacity="0.8" TextWrapping="Wrap" MaxLines="2"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>

                    <Grid x:Name="ModloadersView" IsVisible="False">
                        <StackPanel Spacing="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
                            <TextBlock Text="Framework Installation" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <ComboBox x:Name="ModloaderVersionComboBox" HorizontalAlignment="Stretch" CornerRadius="10" Height="45"/>
                            <Grid ColumnDefinitions="*, *">
                                <Button x:Name="InstallForgeButton" Content="Forge" Grid.Column="0" Margin="0,0,10,0" Height="50" CornerRadius="12" Background="#DF9444" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                                <Button x:Name="InstallFabricButton" Content="Fabric" Grid.Column="1" Margin="10,0,0,0" Height="50" CornerRadius="12" Background="#F0D697" Foreground="Black" FontWeight="Bold" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Grid x:Name="ChangelogsView" IsVisible="False" ColumnDefinitions="250, *">
                        <ListBox x:Name="ChangelogVersionListBox" Grid.Column="0" Background="#1E1E1E" CornerRadius="15,0,0,15"/>
                        <Border Grid.Column="1" Background="#151515" CornerRadius="0,15,15,0" Padding="30" BorderThickness="0,1,1,1" BorderBrush="#333333">
                            <ScrollViewer>
                                <TextBlock x:Name="ChangelogContentText" FontSize="14" LineHeight="24" TextWrapping="Wrap" Opacity="0.9"/>
                            </ScrollViewer>
                        </Border>
                    </Grid>

                    <Grid x:Name="ModsView" IsVisible="False" RowDefinitions="Auto, *">
                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,25">
                            <TextBox x:Name="ModSearchTextBox" Watermark="Search Modrinth projects..." Height="45" CornerRadius="10"/>
                            <Button x:Name="SearchModsButton" Content="Search" Grid.Column="1" Margin="15,0,0,0" Height="45" Padding="25,0" CornerRadius="10" Background="#0078D4"/>
                        </Grid>
                        <ListBox x:Name="ModsListBox" Grid.Row="1" Background="Transparent" BorderThickness="0"/>
                    </Grid>
                </Panel>

                <!-- Footer -->
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,30,0,0">
                    <StackPanel Grid.Column="0" Spacing="10" VerticalAlignment="Center" Margin="0,0,30,0">
                        <ProgressBar x:Name="DownloadProgressBar" Height="8" CornerRadius="4" Background="#1E1E1E" Foreground="#0078D4"/>
                        <TextBlock x:Name="StatusTextBlock" Text="Ready to Launch" FontSize="13" Opacity="0.6"/>
                    </StackPanel>
                    
                    <Button x:Name="PlayButton" Grid.Column="1" Width="220" Height="65" CornerRadius="15" Background="#0078D4" Foreground="White">
                        <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}" Width="24" Height="24"/>
                            <TextBlock Text="LAUNCH" FontSize="20" FontWeight="Black" VerticalAlignment="Center" LetterSpacing="2"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Grid>
        </Grid>

        <!-- Overlays -->
        <Grid x:Name="LoadingOverlay" Background="#F2000000" IsVisible="True">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="25">
                <PathIcon Data="{StaticResource IconMods}" Width="120" Height="120" Foreground="#0078D4">
                    <PathIcon.Styles>
                        <Style Selector="PathIcon">
                            <Style.Animations>
                                <Animation Duration="0:0:1.5" IterationCount="Infinite">
                                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                    <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.3"/></KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </PathIcon.Styles>
                </PathIcon>
                <ProgressBar IsIndeterminate="True" Width="200" Height="3" Foreground="#0078D4" Background="Transparent"/>
                <TextBlock x:Name="LoadingStatus" Text="Preparing Midnight..." FontSize="18" FontWeight="Light" Opacity="0.7"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="BrandingOverlay" Background="#000000" IsVisible="False">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <PathIcon Data="{StaticResource IconHeart}" Width="100" Height="100" Foreground="#E91E63"/>
                <TextBlock Text="CStudioss" FontSize="14" LetterSpacing="4" Opacity="0.5" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <StackPanel x:Name="NotificationArea" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="30" Width="320" Spacing="10"/>
    </Panel>
</Window>
