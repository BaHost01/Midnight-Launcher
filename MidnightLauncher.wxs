<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
    <Product Id="*" Name="Midnight Launcher" Language="1033" Version="1.0.0.0" Manufacturer="MidnightTeam" UpgradeCode="6b7a5a8e-4a7b-4d5a-8a7e-4b7a5a8e4a7b">
        <Package InstallerVersion="200" Compressed="yes" InstallScope="perUser" />

        <MajorUpgrade DowngradeErrorMessage="A newer version of [ProductName] is already installed." />
        <MediaTemplate EmbedCab="yes" />

        <Feature Id="ProductFeature" Title="Midnight Launcher" Level="1">
            <ComponentGroupRef Id="ProductComponents" />
            <ComponentRef Id="ApplicationShortcut" />
        </Feature>
    </Product>

    <Fragment>
        <Directory Id="TARGETDIR" Name="SourceDir">
            <Directory Id="AppDataFolder">
                <Directory Id="INSTALLFOLDER" Name="Midnight Launcher" />
            </Directory>
            <Directory Id="ProgramMenuFolder">
                <Directory Id="ApplicationProgramsFolder" Name="Midnight Launcher"/>
            </Directory>
        </Directory>
    </Fragment>

    <Fragment>
        <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
            <Component Id="MainExecutable" Guid="7b7a5a8e-4a7b-4d5a-8a7e-4b7a5a8e4a7c">
                <File Id="MidnightLauncherEXE" Source="publish\win-x64\Midnight-Launcher.exe" KeyPath="yes" />
                <RemoveFolder Id="RemoveINSTALLFOLDER" On="uninstall" />
                <RegistryValue Root="HKCU" Key="Software\MidnightLauncher" Name="installed" Type="integer" Value="1" KeyPath="no" />
            </Component>
            <!-- Add other files here if needed -->
        </ComponentGroup>

        <DirectoryRef Id="ApplicationProgramsFolder">
            <Component Id="ApplicationShortcut" Guid="8b7a5a8e-4a7b-4d5a-8a7e-4b7a5a8e4a7d">
                <Shortcut Id="ApplicationStartMenuShortcut" 
                          Name="Midnight Launcher" 
                          Description="Lightweight Minecraft Launcher"
                          Target="[INSTALLFOLDER]Midnight-Launcher.exe"
                          WorkingDirectory="INSTALLFOLDER"/>
                <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall"/>
                <RegistryValue Root="HKCU" Key="Software\MidnightLauncher" Name="shortcut" Type="integer" Value="1" KeyPath="yes"/>
            </Component>
        </DirectoryRef>
    </Fragment>
</Wix>
